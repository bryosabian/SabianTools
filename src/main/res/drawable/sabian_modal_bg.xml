    <item>
        <shape>
            <solid android:color="@color/google_white" />
            <stroke android:width="1dp" android:color="@android:color/transparent" />
            <corners
                android:bottomLeftRadius="@dimen/sabian_modal_round_radius"
                android:bottomRightRadius="@dimen/sabian_modal_round_radius"
